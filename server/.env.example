NODE_ENV=development
PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ============================================
# EMAIL DELIVERY (use ONE of the two options)
# ============================================
#
# Option 1: Gmail App Password (RECOMMENDED)
#
#   1. Enable 2-Factor Authentication on your Gmail account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password for "Mail"
#   4. Copy the 16-character password (spaces are optional)
#
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password
#
# Option 2: Generic SMTP provider (SendGrid, Mailgun, etc.)
#
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# SMTP_FROM="Elegant Home Decor <noreply@yourdomain.com>"

# ============================================
# EMAIL NOTIFICATIONS
# ============================================
# The sender "name" and "from" address used in all emails.
# Falls back to EMAIL_USER if not set.
MAIL_FROM_NAME=Elegant Home Decor
MAIL_FROM=no-reply@eleganthomedecor.com

# Admin notification recipients (comma-separated for multiple)
ADMIN_EMAIL=admin@eleganthomedecor.com
# EMAIL_ALERT_TO=admin@eleganthomedecor.com,manager@eleganthomedecor.com
LOW_STOCK_THRESHOLD=5

# ============================================
# PRODUCTION DEPLOYMENT (Render + Vercel)
# ============================================
# When deploying on Render, set ALL these in the Render Dashboard:
#   Dashboard -> Your Service -> Environment -> Environment Variables
#
# REQUIRED for production:
#   MONGO_URI         - MongoDB Atlas connection string
#   JWT_SECRET        - Random 64-char hex string
#   EMAIL_USER        - Your Gmail address (if using Gmail App Password)
#   EMAIL_PASS        - Your Gmail App Password
#   ADMIN_EMAIL       - Email to receive order/admin notifications
#   CLIENT_URL        - https://your-vercel-app.vercel.app
#   CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
#   STRIPE_SECRET_KEY (if using Stripe)
#
# Also set in Vercel (frontend) dashboard:
#   VITE_API_URL      - https://your-render-app.onrender.com/api
#                       (MUST include /api suffix)
#
# IMPORTANT: Render's free tier may block outbound SMTP on port 587.
# If emails fail in production, try:
#   1. EMAIL_SMTP_PORT=465 and EMAIL_SECURE=true
#   2. Or switch to SendGrid/Mailgun/MailerSend (free tiers available)

# Payments and uploads
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
STRIPE_SECRET_KEY=your_stripe_secret_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
